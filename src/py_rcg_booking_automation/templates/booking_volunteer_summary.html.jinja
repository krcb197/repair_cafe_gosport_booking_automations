<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{event.title}}</title>
    <style>
    h1 {text-align: center; font-family: sans-serif;}
    p { font-family: sans-serif; font-size: 90%; }
    table, th, td {
        border: 2px solid black;
        border-collapse: collapse;
    }
    </style>
</head>
<body>
<h1>{{event.title}}</h1>
<table border=0>
    <tr>
        <th><p>Reference</p></th>
        <th><p>What type of Broken Thing do you want help with</p></th>
        <th><p>Description of the Broken Things</p></th>
        <th><p>Description of the Fault</p></th>
        <th><p>Picture</p></th>
    </tr>
    {% for ticket in tickets %}
    <tr>
        <td><p>{{ticket.reference}}</p></td>
        <td><p>{{ticket.repair_type}}</p></td>
        <td><p>{{ticket.repair_item}}</p></td>
        <td><p>{{ticket.repair_fault}}</p></td>
        <td><p>{% if ticket.repair_picture_present %} <a href="https://lh3.googleusercontent.com/d/{{ticket_pictures[ticket.reference].google_drive_file_id}}"><img src="https://lh3.googleusercontent.com/d/{{ticket_pictures[ticket.reference].google_drive_file_id}}" width="200" ></a> {% else %} None Provided {% endif %} </p></td>
    </tr>
    {% endfor %}
</table>
</body>
</html>